model Character {
  // Common
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Properties
  name String @unique

  // Relationships
  defaultPilotId Int?
  defaultPilot   GuildMember?        @relation(fields: [defaultPilotId], references: [id])
  guildId        Int
  guild          Guild               @relation(fields: [guildId], references: [id])
  classId        Int
  class          CharacterClass      @relation(fields: [classId], references: [id])
  raceId         Int
  race           CharacterRace       @relation(fields: [raceId], references: [id])
  transactions   WalletTransaction[]

  // Indexes
  @@index([defaultPilotId])
  @@index([guildId])
  @@index([classId])
  @@index([raceId])
}

model CharacterClass {
  // Common
  id Int @id @default(autoincrement())

  // Properties
  name          String @unique
  colorHexDark  String
  colorHexLight String

  // Relationships
  gameId                Int
  game                  Game                   @relation(fields: [gameId], references: [id])
  characters            Character[]
  raceClassCombinations RaceClassCombination[]
}

model CharacterRace {
  // Common
  id Int @id @default(autoincrement())

  // Properties
  name String @unique

  // Relationships
  gameId                Int
  game                  Game                   @relation(fields: [gameId], references: [id])
  characters            Character[]
  raceClassCombinations RaceClassCombination[]
}

model RaceClassCombination {
  // Common
  id Int @id @default(autoincrement())

  // Relationships
  raceId  Int
  race    CharacterRace  @relation(fields: [raceId], references: [id])
  classId Int
  class   CharacterClass @relation(fields: [classId], references: [id])
}
