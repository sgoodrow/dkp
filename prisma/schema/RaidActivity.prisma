model RaidActivity {
  // Common
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Properties
  note String?

  // Relationships
  transactions    WalletTransaction[]
  typeId          Int
  type            RaidActivityType    @relation(fields: [typeId], references: [id])
  createdById     Int
  createdByMember GuildMember         @relation("RaidActivityCreator", fields: [createdById], references: [id])
  updatedById     Int
  updatedByMember GuildMember         @relation("RaidActivityLatestUpdater", fields: [updatedById], references: [id])
}

model RaidActivityType {
  // Common
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Properties
  name          String @unique
  defaultPayout Float

  // Relationships
  guildId         Int
  guild           Guild          @relation(fields: [guildId], references: [id])
  raidActivities  RaidActivity[]
  createdById     Int
  createdByMember GuildMember    @relation("RaidActivityTypeCreator", fields: [createdById], references: [id])
  updatedById     Int
  updatedByMember GuildMember    @relation("RaidActivityTypeLatestUpdater", fields: [updatedById], references: [id])
}
